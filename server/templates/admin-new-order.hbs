<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Novo Pedido Recebido - Empório Gelada</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background-color: #f8f8f8;
      color: #333;
      line-height: 1.6;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    .card {
      background-color: #ffffff;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
      padding: 48px 40px;
    }
    .logo {
      text-align: center;
      margin-bottom: 32px;
    }
    .logo h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 28px;
      font-weight: 400;
      color: #000;
      margin: 0;
      letter-spacing: 4px;
    }
    .logo span {
      font-size: 12px;
      color: #999;
      letter-spacing: 2px;
    }
    .divider {
      height: 1px;
      background-color: #e5e5e5;
      margin: 24px 0;
    }
    h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 24px;
      font-weight: 400;
      color: #000;
      margin: 0 0 16px 0;
    }
    h3 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 18px;
      font-weight: 400;
      color: #000;
      margin: 24px 0 12px 0;
    }
    p {
      font-size: 14px;
      color: #666;
      margin: 0 0 16px 0;
    }
    .alert-banner {
      background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
      border-left: 4px solid #f59e0b;
      padding: 16px 20px;
      margin: 24px 0;
      border-radius: 0 8px 8px 0;
    }
    .alert-banner p {
      margin: 0;
      color: #92400e;
      font-weight: 500;
    }
    .order-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background-color: #000;
      color: #fff;
      padding: 20px;
      border-radius: 8px;
      margin: 24px 0;
    }
    .order-header .order-id {
      font-size: 12px;
      opacity: 0.7;
      margin-bottom: 4px;
    }
    .order-header .order-number {
      font-size: 24px;
      font-weight: 600;
    }
    .order-header .order-total {
      text-align: right;
    }
    .order-header .total-label {
      font-size: 12px;
      opacity: 0.7;
    }
    .order-header .total-value {
      font-size: 24px;
      font-weight: 600;
    }
    .customer-info {
      background-color: #f8f8f8;
      border-radius: 4px;
      padding: 20px;
      margin: 16px 0;
    }
    .customer-info p {
      margin: 4px 0;
      font-size: 13px;
    }
    .item {
      display: flex;
      padding: 16px 0;
      border-bottom: 1px solid #f0f0f0;
    }
    .item:last-child {
      border-bottom: none;
    }
    .item-details {
      flex: 1;
    }
    .item-name {
      font-size: 14px;
      color: #000;
      font-weight: 500;
      margin: 0 0 4px 0;
    }
    .item-variant {
      font-size: 12px;
      color: #999;
      margin: 0;
    }
    .item-price {
      font-size: 14px;
      color: #000;
      font-weight: 500;
    }
    .summary {
      background-color: #f8f8f8;
      border-radius: 4px;
      padding: 20px;
      margin-top: 24px;
    }
    .summary-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      font-size: 14px;
    }
    .summary-row.total {
      border-top: 1px solid #e5e5e5;
      margin-top: 8px;
      padding-top: 16px;
      font-weight: 600;
      font-size: 16px;
      color: #000;
    }
    .status-badge {
      display: inline-block;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .status-pending { background-color: #fef3c7; color: #92400e; }
    .status-paid { background-color: #d1fae5; color: #065f46; }
    .button-container {
      text-align: center;
      margin: 32px 0;
    }
    .button {
      display: inline-block;
      background-color: #000;
      color: #fff !important;
      text-decoration: none;
      padding: 16px 48px;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      border-radius: 0;
    }
    .footer {
      text-align: center;
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid #e5e5e5;
    }
    .footer p {
      font-size: 12px;
      color: #999;
    }
    .highlight {
      color: #000;
      font-weight: 500;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    td {
      padding: 4px 0;
      font-size: 13px;
    }
    td:first-child {
      color: #999;
    }
    td:last-child {
      color: #000;
      text-align: right;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="logo">
        <h1>EMPÓRIO GELADA</h1>
        <span>PAINEL ADMINISTRATIVO</span>
      </div>
      
      <div class="divider"></div>
      
      <div class="alert-banner">
        <p>Novo pedido recebido! Verifique os detalhes abaixo.</p>
      </div>

      <div class="order-header">
        <div>
          <div class="order-id">Pedido</div>
          <div class="order-number">#{{orderNumber}}</div>
        </div>
        <div class="order-total">
          <div class="total-label">Total</div>
          <div class="total-value">{{total}}</div>
        </div>
      </div>

      <div style="margin-bottom: 16px;">
        <span class="status-badge status-{{statusClass}}">{{statusText}}</span>
        <span style="margin-left: 8px; font-size: 12px; color: #999;">{{paymentMethod}}</span>
      </div>

      <h3>Dados do Cliente</h3>
      <div class="customer-info">
        <table>
          <tr>
            <td>Nome</td>
            <td><strong>{{customerName}}</strong></td>
          </tr>
          <tr>
            <td>E-mail</td>
            <td>{{customerEmail}}</td>
          </tr>
          {{#if customerPhone}}
          <tr>
            <td>Telefone</td>
            <td>{{customerPhone}}</td>
          </tr>
          {{/if}}
        </table>
      </div>

      <h3>Endereço de Entrega</h3>
      <div class="customer-info">
        <p><strong>{{shippingName}}</strong></p>
        <p>{{shippingAddress}}</p>
        <p>{{shippingCity}}</p>
        <p>CEP: {{shippingZip}}</p>
        {{#if shippingPhone}}
        <p>Telefone: {{shippingPhone}}</p>
        {{/if}}
      </div>
      
      <h3>Itens do Pedido</h3>
      
      {{#each items}}
      <div class="item">
        <div class="item-details">
          <p class="item-name">{{this.name}}</p>
          <p class="item-variant">Tamanho: {{this.size}} | Qtd: {{this.quantity}}</p>
        </div>
        <div class="item-price">{{this.priceFormatted}}</div>
      </div>
      {{/each}}
      
      <div class="summary">
        <div class="summary-row">
          <span>Subtotal</span>
          <span>{{subtotal}}</span>
        </div>
        {{#if discount}}
        <div class="summary-row">
          <span>Desconto ({{couponCode}})</span>
          <span style="color: #059669;">-{{discount}}</span>
        </div>
        {{/if}}
        <div class="summary-row">
          <span>Frete ({{shippingMethod}})</span>
          <span>{{shipping}}</span>
        </div>
        <div class="summary-row total">
          <span>Total</span>
          <span>{{total}}</span>
        </div>
      </div>
      
      <div class="button-container">
        <a href="{{adminUrl}}" class="button">Gerenciar Pedido</a>
      </div>
      
      <div class="divider"></div>
      
      <p style="font-size: 12px; color: #999; text-align: center;">
        Pedido realizado em {{orderDate}} às {{orderTime}}
      </p>
      
      <div class="footer">
        <p>&copy; {{year}} Empório Gelada. Notificação administrativa.</p>
      </div>
    </div>
  </div>
</body>
</html>
